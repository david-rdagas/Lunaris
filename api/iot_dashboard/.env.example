# ── Autenticación ─────────────────────────────────────────────────────────────
# Cambia esto antes de producción
API_KEY=iot-dev-key-changeme

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=mi-token-influx
INFLUX_ORG=mi-org
INFLUX_BUCKET=iot

# ── WebSocket broadcast ────────────────────────────────────────────────────────
BROADCAST_INTERVAL=2.0

# ── CORS (lista separada por comas) ───────────────────────────────────────────
# En producción, pon el origen de Grafana exacto
CORS_ORIGINS=["*"]

# ── Umbrales de alerta ────────────────────────────────────────────────────────
ALERT_WINDOW_MINUTES=5
ALERT_TEMP_HIGH=80.0
ALERT_TEMP_LOW=-10.0
ALERT_HUM_HIGH=90.0
ALERT_PRES_LOW=950.0
ALERT_PRES_HIGH=1050.0
